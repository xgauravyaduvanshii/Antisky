# ===================================
# Antisky Platform — Environment Variables
# ===================================
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL=postgres://antisky:password@localhost:5432/antisky?sslmode=disable
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_ARTIFACTS=antisky-artifacts-dev
S3_BUCKET_STATIC=antisky-static-dev
ECR_REGISTRY=
ECS_CLUSTER=antisky-dev
SQS_BUILD_QUEUE_URL=

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# --- Platform ---
PLATFORM_URL=http://localhost:3000
API_URL=http://localhost:8080
AUTH_URL=http://localhost:8081

# --- Encryption ---
ENCRYPTION_KEY=your-32-byte-encryption-key-here
